#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
workspace_root="$(cd "$script_dir/.." && pwd)"
export NUCLEUS_WORKSPACE_ROOT="$workspace_root"

# A run owns one log across the workspace build, runtime staging, and the
# compositor/shell session. Keep tee outside the exec chain: the workspace CLI
# replaces itself with nucleus-session, so every descendant inherits this same
# stdout/stderr pipe while signals still reach the session directly.
if [[ "${1:-}" == run ]]; then
  run_help=0
  for run_argument in "${@:2}"; do
    if [[ "$run_argument" == -h || "$run_argument" == --help ]]; then
      run_help=1
      break
    fi
  done
  if [[ "$run_help" -eq 0 ]]; then
    command -v tee >/dev/null 2>&1 || {
      echo "error: tee is required to capture a Nucleus run log" >&2
      exit 127
    }
    run_log_directory="$workspace_root/logs"
    mkdir -p -- "$run_log_directory"
    run_timestamp="$(date -u +%Y%m%dT%H%M%S.%NZ)"
    run_log_name="nucleus-$run_timestamp-$$.log"
    run_log_path="$run_log_directory/$run_log_name"
    if ! (set -o noclobber; : > "$run_log_path"); then
      echo "error: could not create run log: $run_log_path" >&2
      exit 1
    fi
    latest_temporary="$run_log_directory/.latest.$$"
    ln -s -- "$run_log_name" "$latest_temporary"
    if ! mv -Tf -- "$latest_temporary" "$run_log_directory/latest"; then
      unlink -- "$latest_temporary" 2>/dev/null || true
      echo "error: could not update run log symlink: $run_log_directory/latest" >&2
      exit 1
    fi
    export NUCLEUS_RUN_LOG="$run_log_path"
    exec > >(trap '' INT TERM; exec tee -a -- "$run_log_path") 2>&1
    echo "run log: $run_log_path"
  fi
fi

# A first user-level platform generation can be orchestrated with a Swift 6.4
# bootstrap compiler on PATH. Every other command requires the active Nucleus
# generation (or an explicit toolchain override).
if [[ "${1:-}" == toolchain && "${2:-}" == rebuild ]]; then
  source_id="${NUCLEUS_SWIFT_SOURCE_ID:-release-6.4.x}"
  platform_id="$source_id"
  if [[ "$(uname -s)" == Darwin ]]; then platform_id="$source_id-macos"; fi
  user_platform="${XDG_CACHE_HOME:-$HOME/.cache}/nucleus/swift-platforms/$platform_id/current/toolchain/usr"
  if [[ ( -n "${NUCLEUS_SWIFT_TOOLCHAIN:-}" && -x "$NUCLEUS_SWIFT_TOOLCHAIN/bin/swift-build" ) ||
        -x "$user_platform/bin/swift-build" ]]; then
    source "$workspace_root/tools/host-env.sh"
  elif ! command -v swift >/dev/null 2>&1; then
    echo "error: Swift 6.4 is required on PATH to create the first Nucleus toolchain generation" >&2
    exit 127
  fi
  unset source_id platform_id user_platform
else
  source "$workspace_root/tools/host-env.sh"
fi

swift build --package-path "$workspace_root" --product nucleus-workspace
workspace_bin="$(swift build --package-path "$workspace_root" --show-bin-path)"
exec "$workspace_bin/nucleus-workspace" "$@"
