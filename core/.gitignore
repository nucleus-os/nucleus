*.csv
.DS_Store
.AppleDouble
.LSOverride
Icon?
Thumbs.db
ehthumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Editors/IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
.claude/

# ─────────────────────────────────────────────────────────────────────────────
# Node / RN / Metro (bun workspaces)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.patches/
.pnpm/
.pnpm-store/
.npm/
.yarn/
.yarnrc
.yarnrc.yml

# logs
*.log
pnpm-debug.log*
.npm-debug.log*
yarn-debug.log*
yarn-error.log*

# lockfiles — keep bun.lock, ignore others
package-lock.json
yarn.lock
pnpm-lock.yaml

# Metro / Watchman caches
.haste/
metro-cache/
.watchman
.expo/
.expo-shared/

# ─────────────────────────────────────────────────────────────────────────────
# C/C++ / CMake / toolchains
# ─────────────────────────────────────────────────────────────────────────────
build/
build-*/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
compile_commands.json

# Zig build artifacts
.zig-cache/
zig-out/
zig-pkg/
build.err
build.out

# SwiftPM build artifacts
swift/.build/
# SwiftPM scratch dirs created by build.zig's swift build invocations
# (.build-native/, .build-rn-proof/, etc. each hold cloned dep checkouts)
.build-*/

# CEF binary distribution (downloaded by zig build)
.cef-cache/

# compiled artifacts
*.o
*.obj
*.a
*.lib
*.dll
*.dylib
*.so
*.exe
*.pdb
*.ilk
*.exp
*.node

# ─────────────────────────────────────────────────────────────────────────────
# Optional mobile folders (if you add sample iOS/Android apps later)
# ─────────────────────────────────────────────────────────────────────────────
# Android
android/.gradle/
android/.cxx/
android/local.properties
android/build/
android/app/build/

# iOS
ios/Pods/
ios/build/
ios/DerivedData/
*.xcuserdatad
*.xcscmblueprint
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# ─────────────────────────────────────────────────────────────────────────────
# Tests / coverage (JS)
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
jest-cache/
jest-stare/
.tap

# ─────────────────────────────────────────────────────────────────────────────
# Codegen
# ─────────────────────────────────────────────────────────────────────────────
# Stub files generated by codegen (scaffolding for developers to copy)
.codegen/

# ─────────────────────────────────────────────────────────────────────────────
# Temp / misc
# ─────────────────────────────────────────────────────────────────────────────
tmp/
.temp/
.tmp/
.cache/
.build-cache/
profiles/
dist/
packages/react-native-nucleus-component/dist/

# env files (keep an example if you want)
.env
.env.*
!.env.example
*.log
.direnv/

# SwiftPM
/.build/
.swiftpm/
Tools/.build/
/build_zig/

# SwiftPM Phase-5 Skia GN/Ninja build output (plugin-driven, not committed)
.skia-build/

# Phase-5 RN/Hermes C++ build output (plugin-driven, not committed)
.rn-build/

# tracy-capture receiver, cmake-built from third-party/tracy (not committed)
.tracy-build/

# Phase-5 boost headers (fetched, not committed)
third-party/boost/

# Compositor app package (compositor/Package.swift) build artifacts
compositor/.build/

# Android host package (platform-android/Package.swift) cross-compile output
platform-android/.build/

# Compositor install prefix (install-compositor plugin output)
compositor/.install/
compositor-core/.build/
