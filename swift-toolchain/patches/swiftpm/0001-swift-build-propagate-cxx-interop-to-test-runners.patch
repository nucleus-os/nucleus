new file mode 100644
index 00000000..025677b8
--- /dev/null
+++ b/Fixtures/CFamilyTargets/CxxInteropTestRunner/Package.swift
@@ -0,0 +1,16 @@
+// swift-tools-version: 6.4
+import PackageDescription
+
+let package = Package(
+    name: "CxxInteropTestRunner",
+    products: [.library(name: "Example", targets: ["Example"])],
+    targets: [
+        .target(name: "Example"),
+        .testTarget(
+            name: "ExampleTests",
+            dependencies: ["Example"],
+            swiftSettings: [
+                .interoperabilityMode(.Cxx),
+                .unsafeFlags(["-DTEST_MODULE_ONLY"]),
+            ])
+    ])
