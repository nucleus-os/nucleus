Subject: [PATCH] SwiftBuild: propagate C++ interop to generated test runners

Swift Build creates a separate synthesized runner which imports each test
module. Unlike the native build planner, the PIF path did not copy a test
module's C++ interoperability mode to that runner. Importing a Swift module
built with C++ interop from the plain runner consequently failed with:

  module was built with C++ interoperability enabled, but current compilation
  does not enable C++ interoperability

Propagate only the manifest's interoperability mode and its adjacent C++
language-standard argument, preserving configuration and platform conditions.
Do not copy unrelated unsafe Swift flags from the test module.

Sentinel: NUCLEUS_SWIFTPM_TEST_RUNNER_CXX_INTEROP

diff --git a/Sources/SwiftBuildSupport/PackagePIFBuilder+Helpers.swift b/Sources/SwiftBuildSupport/PackagePIFBuilder+Helpers.swift
index ee5652fe..e33915a0 100644
--- a/Sources/SwiftBuildSupport/PackagePIFBuilder+Helpers.swift
+++ b/Sources/SwiftBuildSupport/PackagePIFBuilder+Helpers.swift
@@ -674,6 +674,48 @@ extension PackageGraph.ResolvedModule {
             }
         }
 
+        // NUCLEUS_SWIFTPM_TEST_RUNNER_CXX_INTEROP: A Swift Build test runner is
+        // a distinct synthesized target which imports the test module. Preserve
+        // the test module's C++ interop mode on that import boundary, matching
+        // the native build planner's generated-entry-point propagation.
+        func applyCxxInterop(to buildSettings: inout ProjectModel.BuildSettings,
+                             for configuration: BuildConfiguration) {
+            guard let multipleValuesByPlatform = targetMultipleValueSettings[configuration] else {
+                return
+            }
+            for (platform, multipleValues) in multipleValuesByPlatform {
+                guard let swiftFlags = multipleValues[.OTHER_SWIFT_FLAGS] else { continue }
+                var interopFlags: [String] = []
+                var index = swiftFlags.startIndex
+                while index < swiftFlags.endIndex {
+                    let flag = swiftFlags[index]
+                    guard flag.hasPrefix("-cxx-interoperability-mode=") else {
+                        index = swiftFlags.index(after: index)
+                        continue
+                    }
+                    interopFlags.append(flag)
+                    index = swiftFlags.index(after: index)
+                    if index < swiftFlags.endIndex, swiftFlags[index] == "-Xcc" {
+                        let standardIndex = swiftFlags.index(after: index)
+                        if standardIndex < swiftFlags.endIndex,
+                           swiftFlags[standardIndex].hasPrefix("-std=") {
+                            interopFlags.append("-Xcc")
+                            interopFlags.append(swiftFlags[standardIndex])
+                            index = swiftFlags.index(after: standardIndex)
+                        }
+                    }
+                }
+                guard !interopFlags.isEmpty else { continue }
+                if let platform {
+                    let inherited = buildSettings[.OTHER_SWIFT_FLAGS, platform] ?? ["$(inherited)"]
+                    buildSettings[.OTHER_SWIFT_FLAGS, platform] = inherited + interopFlags
+                } else {
+                    let inherited = buildSettings[.OTHER_SWIFT_FLAGS] ?? ["$(inherited)"]
+                    buildSettings[.OTHER_SWIFT_FLAGS] = inherited + interopFlags
+                }
+            }
+        }
+
         /// Apply imparted settings to a ProjectModel.BuildSettings instance
         func applyImparted(to buildSettings: inout ProjectModel.BuildSettings) {
             // Apply imparted single value settings for all platforms
diff --git a/Sources/SwiftBuildSupport/PackagePIFProjectBuilder+Products.swift b/Sources/SwiftBuildSupport/PackagePIFProjectBuilder+Products.swift
