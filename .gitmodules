[submodule "core/third-party/skia"]
	path = core/third-party/skia
	url = git@github.com:maddythewisp/skia.git
	branch = nucleus-vulkan-render-pass-dependencies
[submodule "core/third-party/libxkbcommon"]
	path = core/third-party/libxkbcommon
	url = https://github.com/xkbcommon/libxkbcommon.git
[submodule "third-party/swift-system"]
	path = third-party/swift-system
	url = git@github.com:maddythewisp/swift-system.git
	branch = nucleus
[submodule "third-party/swift-java"]
	path = third-party/swift-java
	url = git@github.com:maddythewisp/swift-java.git
	branch = nucleus-cxx-interop
[submodule "third-party/swift-java-jni-core"]
	path = third-party/swift-java-jni-core
	url = git@github.com:maddythewisp/swift-java-jni-core.git
	branch = nucleus-cxx-interop
[submodule "react-native/third-party/hermes"]
