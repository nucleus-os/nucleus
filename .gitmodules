	path = react-native/third-party/glog
	url = https://github.com/google/glog
[submodule "react-native/third-party/fmt"]
	path = react-native/third-party/fmt
	url = https://github.com/fmtlib/fmt
[submodule "react-native/third-party/fast_float"]
	path = react-native/third-party/fast_float
	url = https://github.com/fastfloat/fast_float
[submodule "react-native/third-party/react-native"]
	path = react-native/third-party/react-native
