+#include "build/build_config.h"
 #include "chrome/browser/ui/color/chrome_color_id.h"
 #include "chrome/browser/ui/color/chrome_color_provider_utils.h"
+#include "chrome/browser/ui/views/frame/glass_frame_constants.h"
 #include "third_party/skia/include/core/SkColor.h"
 #include "ui/base/ui_base_features.h"
 #include "ui/color/color_id.h"
@@ -518,4 +520,24 @@ void AddOmniboxColorMixer(ui::ColorProvider* provider,
 
   // Apply specific baseline colors for the composebox submit button.
   ApplyComposeboxBaselineColors(mixer, key);
+
+#if BUILDFLAG(IS_LINUX)
+  if (features::IsGlassFrameEnabled() &&
+      !high_contrast_custom_handling) {
+    // Preserve the normal color derivation and contrast calculations above,
+    // then apply alpha in a later mixer. The popup is already a translucent
+    // native surface, and niri supplies blur for browser popup surfaces.
+    ui::ColorMixer& glass_mixer = provider->AddMixer();
+    glass_mixer[kColorOmniboxResultsBackground] = ui::SetAlpha(
+        ui::FromTransformInput(), glass_frame::kLinuxPopupTintAlpha);
+    glass_mixer[kColorOmniboxResultsBackgroundIph] = ui::SetAlpha(
+        ui::FromTransformInput(), glass_frame::kLinuxPopupTintAlpha);
+    glass_mixer[kColorOmniboxResultsBackgroundHovered] = ui::SetAlpha(
+        ui::FromTransformInput(),
+        glass_frame::kLinuxPopupSelectionTintAlpha);
+    glass_mixer[kColorOmniboxResultsBackgroundSelected] = ui::SetAlpha(
+        ui::FromTransformInput(),
+        glass_frame::kLinuxPopupSelectionTintAlpha);
+  }
+#endif
 }
