 int BrowserFrameViewLinux::GetTranslucentTopAreaHeight() const {
+#if BUILDFLAG(IS_LINUX)
+  if (features::IsGlassFrameEnabled() &&
+      GetBrowserView()->browser()->is_type_normal() &&
+      !browser_widget()->IsFullscreen()) {
+    const int laid_out_height =
+        GetBrowserView()->contents_container()->GetBoundsInScreen().y() -
+        GetBoundsInScreen().y();
+    if (laid_out_height > 0) {
+      return std::min(laid_out_height, height());
+    }
+
+    // Frame hints can be requested before the first BrowserView layout.
+    // Conservatively exclude the expected top-chrome band from the opaque
+    // region until laid-out bounds are available.
+    const int fallback_height =
+        GetTopAreaHeight() +
+        GetBrowserView()->toolbar()->GetPreferredSize().height();
+    return std::min(fallback_height, height());
+  }
+#endif
   return 0;
 }
 
