       opaque_region.push_back(
           gfx::ScaleToEnclosingRect(opaque_region_dip, scale));
     }
+    if (features::IsGlassFrameEnabled() &&
+        browser_view_->ShouldDrawVerticalTabStrip()) {
+      // Wayland's opaque region is a correctness promise, not merely a
+      // performance hint. The vertical sidebar is translucent for its full
+      // height and its hover expansion can reach the configured maximum width.
+      // Conservatively remove that leading band from every opaque rectangle so
+      // the compositor may blend and blur both the collapsed strip and every
+      // intermediate hover-expanded width. Opaque web content still covers
+      // this area normally, so omitting it from the hint does not change its
+      // pixels.
+      gfx::Rect opaque_content_bounds(widget_size);
+      const int translucent_sidebar_width =
+          std::min(VerticalTabStripRegionView::kUncollapsedMaxWidth,
+                   opaque_content_bounds.width());
+      if (base::i18n::IsRTL()) {
+        opaque_content_bounds.set_width(opaque_content_bounds.width() -
+                                        translucent_sidebar_width);
+      } else {
+        opaque_content_bounds.set_x(translucent_sidebar_width);
+        opaque_content_bounds.set_width(opaque_content_bounds.width() -
+                                        translucent_sidebar_width);
+      }
+      const gfx::Rect opaque_content_bounds_px =
+          gfx::ScaleToEnclosedRect(opaque_content_bounds, scale);
+      for (gfx::Rect& rect : opaque_region) {
+        rect.Intersect(opaque_content_bounds_px);
+      }
+      std::erase_if(opaque_region,
+                    [](const gfx::Rect& rect) { return rect.IsEmpty(); });
+    }
     window->SetOpaqueRegion(opaque_region);
   }
 
