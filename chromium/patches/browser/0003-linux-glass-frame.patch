new file mode 100644
index 0000000000..5fdb84ffff
--- /dev/null
+++ b/chrome/browser/ui/views/frame/glass_frame_constants.h
@@ -0,0 +1,38 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_GLASS_FRAME_CONSTANTS_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_GLASS_FRAME_CONSTANTS_H_
+
+#include "third_party/skia/include/core/SkColor.h"
+
+namespace glass_frame {
+
+// Linux compositors provide the blur behind Chromium's transparent native
+// surface. Keep enough of Chromium's theme color to preserve contrast while
+// still exposing that compositor-provided material.
+inline constexpr SkAlpha kLinuxTintAlpha = 0xB8;
+inline constexpr float kLinuxTintOpacity =
+    static_cast<float>(kLinuxTintAlpha) / SK_AlphaOPAQUE;
+
+// Controls such as the omnibox sit above an already-tinted frame material.
+// Keep this overlay light: alpha compounds with the frame tint, so a strong
+// second fill would leave too little compositor-provided blur visible.
+inline constexpr SkAlpha kLinuxControlTintAlpha = 0x60;
+
+// Sidebar controls are composited over an already-tinted glass surface. A
+// lighter overlay preserves their shape without combining into an almost
+// opaque gray island.
+inline constexpr SkAlpha kLinuxSidebarControlTintAlpha = 0x60;
+
+// The omnibox results live in a separate translucent popup surface. Keep its
+// base material consistent with the frame and use the lighter control tint for
+// selected rows so compositor-provided popup blur remains visible.
+inline constexpr SkAlpha kLinuxPopupTintAlpha = kLinuxTintAlpha;
+inline constexpr SkAlpha kLinuxPopupSelectionTintAlpha =
+    kLinuxSidebarControlTintAlpha;
+
+}  // namespace glass_frame
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_GLASS_FRAME_CONSTANTS_H_
