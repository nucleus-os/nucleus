+      display_attribs.push_back(minor(node_stat.st_rdev));
+    }
+  }
+#endif
+
   display_attribs.push_back(EGL_PLATFORM_ANGLE_TYPE_ANGLE);
   display_attribs.push_back(static_cast<EGLAttrib>(platform_type));
 
