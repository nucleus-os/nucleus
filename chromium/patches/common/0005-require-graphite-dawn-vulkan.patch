+             switches::kSkiaGraphiteDawnBackendVulkan)
+        << "Graphite/Dawn/Vulkan is required but Dawn is not configured for "
+           "Vulkan";
+
+    gpu_mode_ = gpu::GpuMode::HARDWARE_GRAPHITE;
+    return;
+  }
+
