#!/usr/bin/env python3

import argparse
import hashlib
import json
import os
import pathlib
import shutil
import subprocess
import sys


def fail(message):
    raise SystemExit(f"AOSP source preparation failed: {message}")


def run(arguments, cwd, capture=True):
    process = subprocess.run(
        arguments,
        cwd=cwd,
        check=False,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.PIPE if capture else None,
        text=True,
    )
    if process.returncode != 0:
        detail = ""
        if capture:
            detail = process.stderr.strip() or process.stdout.strip()
        suffix = f": {detail}" if detail else ""
        fail(f"{' '.join(arguments)} exited {process.returncode}{suffix}")
    return process.stdout.strip() if capture else ""


def git_revision(repository, revision="HEAD"):
    return run(["git", "rev-parse", revision], cwd=repository)


def atomic_write(path, contents):
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(path.name + ".tmp")
    temporary.write_bytes(contents)
    temporary.replace(path)


def require_empty_or_repo(source):
    if not source.exists():
        source.mkdir(parents=True)
        return
    if (source / ".repo").is_dir():
        return
    entries = list(source.iterdir())
    if entries:
        fail(
            f"{source} exists without Repo metadata and is not empty; "
            "refusing to overwrite it"
        )


def require_clean(repo, source):
    if not (source / ".repo" / "project.list").is_file():
        return
    command = (
        'dirty="$(git status --porcelain=v1 --untracked-files=normal)"; '
        'if test -n "$dirty"; then '
        'printf "%s\\n%s\\n" "$REPO_PATH" "$dirty" >&2; exit 1; fi'
    )
    run(
        [
            sys.executable,
            str(repo),
            "forall",
            "-c",
            command,
        ],
        cwd=source,
        capture=True,
    )


def verify_initialized_source(source, lock):
    manifest_repository = source / ".repo" / "manifests"
    repo_repository = source / ".repo" / "repo"
    manifest_commit = git_revision(manifest_repository)
    if manifest_commit != lock["platform"]["manifestCommit"]:
        fail(
            f"manifest checkout is {manifest_commit}, "
            f"expected {lock['platform']['manifestCommit']}"
        )
    repo_commit = git_revision(repo_repository)
    if repo_commit != lock["repo"]["commit"]:
        fail(
            f"Repo checkout is {repo_commit}, "
            f"expected {lock['repo']['commit']}"
        )
    default_manifest = manifest_repository / "default.xml"
    digest = hashlib.sha256(default_manifest.read_bytes()).hexdigest()
    if digest != lock["platform"]["defaultManifestSHA256"]:
        fail(
            f"default manifest digest is {digest}, "
            f"expected {lock['platform']['defaultManifestSHA256']}"
        )
    superprojects = sorted(
        (source / ".repo" / "exp-superproject").glob("*-superproject.git")
    )
    if len(superprojects) != 1:
        fail(
            "Repo must materialize exactly one pinned experimental "
            "superproject checkout"
        )
    superproject_commit = git_revision(superprojects[0])
    if superproject_commit != lock["platform"]["superprojectCommit"]:
        fail(
            f"superproject checkout is {superproject_commit}, "
            f"expected {lock['platform']['superprojectCommit']}"
        )
    return {
        "manifestCommit": manifest_commit,
        "repoCommit": repo_commit,
        "superprojectCommit": superproject_commit,
    }


def main():
    parser = argparse.ArgumentParser(
        description="Materialize the exact AOSP source pinned by Nucleus."
    )
    parser.add_argument("--lock", required=True, type=pathlib.Path)
    parser.add_argument("--repo-launcher", required=True, type=pathlib.Path)
    parser.add_argument("--source", required=True, type=pathlib.Path)
    parser.add_argument("--minimum-free-gib", required=True, type=int)
    arguments = parser.parse_args()

    with arguments.lock.open("rb") as source:
        lock = json.load(source)
    expected_launcher = lock["repo"]["launcherSHA256"]
    actual_launcher = hashlib.sha256(
        arguments.repo_launcher.read_bytes()
    ).hexdigest()
    if actual_launcher != expected_launcher:
        fail(
            f"Repo launcher digest is {actual_launcher}, "
            f"expected {expected_launcher}"
        )
    if arguments.minimum_free_gib <= 0:
        fail("minimum free-space requirement must be positive")

    arguments.source.parent.mkdir(parents=True, exist_ok=True)
    available = shutil.disk_usage(arguments.source.parent).free
    required = arguments.minimum_free_gib * 1024 * 1024 * 1024
    if available < required:
        fail(
            f"{arguments.source.parent} has "
            f"{available // (1024 ** 3)} GiB free; "
            f"{arguments.minimum_free_gib} GiB is required"
        )

    require_empty_or_repo(arguments.source)
    require_clean(arguments.repo_launcher, arguments.source)
    platform = lock["platform"]
    repo = lock["repo"]
    run(
        [
            sys.executable,
            str(arguments.repo_launcher),
            "init",
            "--quiet",
            "--partial-clone",
            "--clone-filter=blob:limit=10M",
            "--use-superproject",
            "--no-clone-bundle",
            f"--repo-url={repo['repositoryURL']}",
            f"--repo-rev={repo['revision']}",
            "-u",
            platform["manifestURL"],
            "-b",
            platform["revision"],
        ],
        cwd=arguments.source,
        capture=False,
    )
    initialized = verify_initialized_source(arguments.source, lock)
    require_clean(arguments.repo_launcher, arguments.source)

    jobs = max(1, min(os.cpu_count() or 1, 32))
    run(
        [
            sys.executable,
            str(arguments.repo_launcher),
            "sync",
            "--current-branch",
            "--detach",
            "--fail-fast",
            "--no-clone-bundle",
            "--no-tags",
            "--optimized-fetch",
            "--prune",
            f"--jobs={jobs}",
        ],
        cwd=arguments.source,
        capture=False,
    )
    require_clean(arguments.repo_launcher, arguments.source)
    resolved_manifest = run(
        [
            sys.executable,
            str(arguments.repo_launcher),
            "manifest",
            "--revision-as-HEAD",
        ],
        cwd=arguments.source,
    )
    resolved_bytes = (resolved_manifest + "\n").encode("utf-8")
    resolved_digest = hashlib.sha256(resolved_bytes).hexdigest()
    metadata = arguments.source / ".nucleus"
    atomic_write(metadata / "resolved-manifest.xml", resolved_bytes)
    provenance = {
        "schemaVersion": 1,
        "status": "materialized",
        "release": platform["release"],
        "revision": platform["revision"],
        "manifestCommit": initialized["manifestCommit"],
        "superprojectCommit": initialized["superprojectCommit"],
        "repoCommit": initialized["repoCommit"],
        "resolvedManifestSHA256": resolved_digest,
    }
    atomic_write(
        metadata / "source-provenance.json",
        (
            json.dumps(provenance, sort_keys=True, separators=(",", ":"))
            + "\n"
        ).encode("utf-8"),
    )


if __name__ == "__main__":
    main()
