#!/usr/bin/env python3

import argparse
import hashlib
import json
import pathlib
import re
import subprocess
import tempfile


def fail(message):
    raise SystemExit(f"AOSP source lock verification failed: {message}")


def require_keys(value, expected, location):
    if not isinstance(value, dict):
        fail(f"{location} must be an object")
    actual = set(value)
    expected = set(expected)
    if actual != expected:
        missing = sorted(expected - actual)
        unknown = sorted(actual - expected)
        detail = []
        if missing:
            detail.append("missing " + ", ".join(missing))
        if unknown:
            detail.append("unknown " + ", ".join(unknown))
        fail(f"{location} has invalid fields ({'; '.join(detail)})")


def require_hex(value, digits, location):
    if not isinstance(value, str) or not re.fullmatch(
        f"[0-9a-f]{{{digits}}}", value
    ):
        fail(f"{location} must be {digits} lowercase hexadecimal digits")


def run(arguments, cwd=None):
    process = subprocess.run(
        arguments,
        cwd=cwd,
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )
    if process.returncode != 0:
        detail = process.stderr.strip() or process.stdout.strip()
        fail(f"{' '.join(arguments)} exited {process.returncode}: {detail}")
    return process.stdout.strip()


def remote_refs(url, revisions):
    output = run(["git", "ls-remote", url, *revisions])
    refs = {}
    for line in output.splitlines():
        pieces = line.split("\t", 1)
        if len(pieces) != 2:
            fail(f"git ls-remote returned a malformed record for {url}")
        refs[pieces[1]] = pieces[0]
    return refs


def require_remote_ref(refs, revision, expected, location):
    actual = refs.get(revision)
    if actual != expected:
        fail(f"{location} resolved to {actual or 'nothing'}, expected {expected}")


def verify(lock, launcher_path):
    require_keys(lock, ["schemaVersion", "platform", "repo"], "lock")
    if lock["schemaVersion"] != 1:
        fail(f"unsupported schema version {lock['schemaVersion']}")

    platform = lock["platform"]
    require_keys(
        platform,
        [
            "release",
            "revision",
            "manifestURL",
            "manifestTagObject",
            "manifestCommit",
            "defaultManifestSHA256",
            "superprojectURL",
            "superprojectRevision",
            "superprojectCommit",
        ],
        "platform",
    )
    repo = lock["repo"]
    require_keys(
        repo,
        [
            "launcherURL",
            "launcherVersion",
            "launcherSHA256",
            "repositoryURL",
            "revision",
            "tagObject",
            "commit",
        ],
        "repo",
    )

    if platform["revision"] != "refs/tags/android-17.0.0_r1":
        fail("platform revision must be refs/tags/android-17.0.0_r1")
    approved = {
        "manifestURL": "https://android.googlesource.com/platform/manifest",
        "superprojectURL":
            "https://android.googlesource.com/platform/superproject",
    }
    for key, expected in approved.items():
        if platform[key] != expected:
            fail(f"{key} must be {expected}")
    if repo["launcherURL"] != (
        "https://storage.googleapis.com/git-repo-downloads/repo"
    ):
        fail("Repo launcher URL does not match the approved upstream")
    if repo["repositoryURL"] != "https://gerrit.googlesource.com/git-repo":
        fail("Repo repository URL does not match the approved upstream")
    if repo["revision"] != f"refs/tags/v{repo['launcherVersion']}":
        fail("Repo revision and launcher version disagree")

    for value, digits, location in [
        (platform["manifestTagObject"], 40, "manifest tag object"),
        (platform["manifestCommit"], 40, "manifest commit"),
        (platform["defaultManifestSHA256"], 64, "default manifest digest"),
        (platform["superprojectCommit"], 40, "superproject commit"),
        (repo["launcherSHA256"], 64, "Repo launcher digest"),
        (repo["tagObject"], 40, "Repo tag object"),
        (repo["commit"], 40, "Repo commit"),
    ]:
        require_hex(value, digits, location)

    manifest_refs = remote_refs(
        platform["manifestURL"],
        [platform["revision"], platform["revision"] + "^{}"],
    )
    require_remote_ref(
        manifest_refs,
        platform["revision"],
        platform["manifestTagObject"],
        "manifest tag",
    )
    require_remote_ref(
        manifest_refs,
        platform["revision"] + "^{}",
        platform["manifestCommit"],
        "manifest tag commit",
    )

    with tempfile.TemporaryDirectory(prefix="nucleus-aosp-manifest-") as temporary:
        checkout = pathlib.Path(temporary) / "manifest"
        run(
            [
                "git",
                "clone",
                "--quiet",
                "--filter=blob:none",
                "--depth=1",
                "--single-branch",
                "--branch",
                platform["revision"].removeprefix("refs/tags/"),
                platform["manifestURL"],
                str(checkout),
            ]
        )
        manifest_commit = run(["git", "rev-parse", "HEAD"], cwd=checkout)
        if manifest_commit != platform["manifestCommit"]:
            fail(
                f"manifest checkout is {manifest_commit}, "
                f"expected {platform['manifestCommit']}"
            )
        manifest_digest = hashlib.sha256(
            (checkout / "default.xml").read_bytes()
        ).hexdigest()
        if manifest_digest != platform["defaultManifestSHA256"]:
            fail(
                f"default.xml digest is {manifest_digest}, "
                f"expected {platform['defaultManifestSHA256']}"
            )

    superproject_refs = remote_refs(
        platform["superprojectURL"],
        [platform["superprojectRevision"]],
    )
    require_remote_ref(
        superproject_refs,
        platform["superprojectRevision"],
        platform["superprojectCommit"],
        "superproject revision",
    )

    repo_refs = remote_refs(
        repo["repositoryURL"],
        [repo["revision"], repo["revision"] + "^{}"],
    )
    require_remote_ref(
        repo_refs, repo["revision"], repo["tagObject"], "Repo tag"
    )
    require_remote_ref(
        repo_refs,
        repo["revision"] + "^{}",
        repo["commit"],
        "Repo tag commit",
    )
    launcher = launcher_path.read_bytes()
    if len(launcher) > 2 * 1024 * 1024:
        fail("Repo launcher exceeds the maximum response size")
    launcher_digest = hashlib.sha256(launcher).hexdigest()
    if launcher_digest != repo["launcherSHA256"]:
        fail(
            f"Repo launcher digest is {launcher_digest}, "
            f"expected {repo['launcherSHA256']}"
        )
    version_match = re.search(
        rb"^VERSION = \((\d+), (\d+)\)$", launcher, re.MULTILINE
    )
    if version_match is None:
        fail("Repo launcher does not declare a recognizable version")
    launcher_version = ".".join(
        part.decode("ascii") for part in version_match.groups()
    )
    if launcher_version != repo["launcherVersion"]:
        fail(
            f"Repo launcher version is {launcher_version}, "
            f"expected {repo['launcherVersion']}"
        )

    return {
        "schemaVersion": 1,
        "status": "verified",
        "platform": {
            "release": platform["release"],
            "revision": platform["revision"],
            "manifestTagObject": platform["manifestTagObject"],
            "manifestCommit": platform["manifestCommit"],
            "defaultManifestSHA256": platform["defaultManifestSHA256"],
            "superprojectCommit": platform["superprojectCommit"],
        },
        "repo": {
            "version": repo["launcherVersion"],
            "tagObject": repo["tagObject"],
            "commit": repo["commit"],
            "launcherSHA256": repo["launcherSHA256"],
        },
    }


def main():
    parser = argparse.ArgumentParser(
        description="Verify every remote identity in the Nucleus AOSP source lock."
    )
    parser.add_argument("--lock", required=True, type=pathlib.Path)
    parser.add_argument("--repo-launcher", required=True, type=pathlib.Path)
    parser.add_argument("--output", type=pathlib.Path)
    arguments = parser.parse_args()
    with arguments.lock.open("rb") as source:
        lock = json.load(source)
    report = verify(lock, arguments.repo_launcher)
    encoded = (
        json.dumps(report, sort_keys=True, separators=(",", ":")) + "\n"
    ).encode("utf-8")
    if arguments.output is None:
        print(encoded.decode("utf-8"), end="")
        return
    arguments.output.parent.mkdir(parents=True, exist_ok=True)
    temporary = arguments.output.with_name(arguments.output.name + ".tmp")
    temporary.write_bytes(encoded)
    temporary.replace(arguments.output)


if __name__ == "__main__":
    main()
