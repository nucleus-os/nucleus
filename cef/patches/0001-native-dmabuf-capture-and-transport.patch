+
+void CefVideoConsumerOSR::RegisterPendingFrame(
+    int64_t capture_counter,
+    PendingFrameCallbacks callbacks) {
+  auto existing = pending_frames_.find(capture_counter);
+  if (existing != pending_frames_.end()) {
+    LOG(ERROR) << "Duplicate accelerated paint capture counter "
+               << capture_counter << "; recycling the older frame";
+    CompleteFrame(std::move(existing->second), true);
+    pending_frames_.erase(existing);
+  }
+  pending_frames_.emplace(capture_counter, std::move(callbacks));
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE,
+      base::BindOnce(&CefVideoConsumerOSR::ExpirePendingFrame,
+                     weak_ptr_factory_.GetWeakPtr(), capture_counter),
+      base::Milliseconds(kReleaseFenceTimeoutMs));
+}
+
+void CefVideoConsumerOSR::ExpirePendingFrame(int64_t capture_counter) {
+  auto it = pending_frames_.find(capture_counter);
+  if (it == pending_frames_.end()) {
+    return;
+  }
+  LOG(ERROR) << "Accelerated paint release fence was not supplied before "
+                "timeout for capture counter "
+             << capture_counter << "; recycling frame";
+  auto callbacks = std::move(it->second);
+  pending_frames_.erase(it);
+  CompleteFrame(std::move(callbacks), true);
