+void CefVideoConsumerOSR::SetAcceleratedPaintReleaseFence(
+    int64_t capture_counter,
+    int fd) {
+  if (fd < 0) {
+    DCHECK(false) << "Release fence descriptor is invalid";
+    return;
+  }
+  base::ScopedFD release_fence(HANDLE_EINTR(dup(fd)));
+  PCHECK(release_fence.is_valid());
