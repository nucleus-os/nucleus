+void CefVideoConsumerOSR::CompletePendingFrame(
+    int64_t capture_counter,
+    base::ScopedFD release_fence) {
+  auto it = pending_frames_.find(capture_counter);
+  if (it == pending_frames_.end()) {
+    LOG(ERROR) << "No pending accelerated paint frame for release counter "
+               << capture_counter;
+    return;
+  }
+  auto callbacks = std::move(it->second);
+  pending_frames_.erase(it);
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_VISIBLE},
+      base::BindOnce(&WaitForReleaseFence, std::move(release_fence)),
+      base::BindOnce(&CompleteFrame, std::move(callbacks)));
+}
