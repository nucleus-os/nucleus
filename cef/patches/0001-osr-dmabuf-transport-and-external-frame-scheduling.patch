+gfx::GpuMemoryBufferHandle SharedImageInterfaceInProcessBase::
+    CloneGpuMemoryBufferHandleForExternalConsumer(const Mailbox& mailbox) {
+  base::WaitableEvent completion(
+      base::WaitableEvent::ResetPolicy::MANUAL,
+      base::WaitableEvent::InitialState::NOT_SIGNALED);
+
+  gfx::GpuMemoryBufferHandle handle;
+  ScheduleGpuTask(
+      base::BindOnce(&SharedImageInterfaceInProcessBase::
+                         CloneGpuMemoryBufferHandleOnGpuThread,
+                     this, mailbox, &handle, &completion),
+      /*sync_token_fences=*/{}, SyncToken());
+  completion.Wait();
+  return handle;
+}
+
+void SharedImageInterfaceInProcessBase::
+    CloneGpuMemoryBufferHandleOnGpuThread(
+        const Mailbox& mailbox,
+        gfx::GpuMemoryBufferHandle* handle,
+        base::WaitableEvent* completion) {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(gpu_sequence_checker_);
+  absl::Cleanup completion_runner = [completion] { completion->Signal(); };
+
+  SharedImageFactory* shared_image_factory = GetSharedImageFactoryOnGpuThread();
+  DCHECK(shared_image_factory);
+
+  // A CompoundImageBacking can export its native handle while intentionally
+  // leaving buffer_usage unset. External consumers only need the handle and
+  // its producer fence, so do not route through the generic info helper that
+  // requires buffer_usage.value().
+  if (!shared_image_factory->CloneGpuMemoryBufferHandle(mailbox, *handle)) {
+    LOG(ERROR) << "SharedImageInterfaceInProcessBase: Unable to clone "
+                  "GpuMemoryBufferHandle";
+  }
+}
