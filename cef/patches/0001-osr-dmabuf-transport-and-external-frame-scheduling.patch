+// Copyright (c) 2026 The Chromium Embedded Framework Authors.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CEF_LIBCEF_BROWSER_OSR_EXTERNAL_BEGIN_FRAME_STATE_H_
+#define CEF_LIBCEF_BROWSER_OSR_EXTERNAL_BEGIN_FRAME_STATE_H_
+#pragma once
+
+#include "base/time/time.h"
+#include "cef/include/cef_browser.h"
+#include "components/viz/common/frame_sinks/begin_frame_args.h"
+
+// Enforces the single-in-flight external BeginFrame contract and owns the
+// client callback until the matching Chromium acknowledgment.
+class CefExternalBeginFrameState {
+ public:
+  bool Begin(CefRefPtr<CefExternalBeginFrameCallback> callback);
+  void Complete(bool has_damage);
+
+  bool pending() const { return pending_; }
+
+ private:
+  bool pending_ = false;
+  CefRefPtr<CefExternalBeginFrameCallback> callback_;
+};
+
+viz::BeginFrameArgs MakeExternalBeginFrameArgs(
+    uint64_t source_id,
+    uint64_t sequence_number,
+    base::TimeTicks frame_time,
+    int64_t deadline_delta_ns,
+    int64_t interval_ns);
+
+#endif  // CEF_LIBCEF_BROWSER_OSR_EXTERNAL_BEGIN_FRAME_STATE_H_
