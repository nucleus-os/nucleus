+
+void CefVideoConsumerOSR::RegisterPendingFrame(
+    int64_t capture_counter,
+    PendingFrameCallbacks callbacks) {
+  auto existing = pending_frames_.find(capture_counter);
+  if (existing != pending_frames_.end()) {
+    LOG(ERROR) << "Duplicate accelerated paint capture counter "
+               << capture_counter << "; recycling the older frame";
+    CompleteFrame(std::move(existing->second), true);
+    pending_frames_.erase(existing);
+  }
+  pending_frames_.emplace(capture_counter, std::move(callbacks));
+}
