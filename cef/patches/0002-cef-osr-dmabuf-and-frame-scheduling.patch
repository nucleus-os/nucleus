+      return;
+    }
+    gfx::GpuFenceHandle release_fence;
+    release_fence.Adopt(std::move(duplicated_fd));
+    offscreen_output_->ReleaseFrame(capture_counter,
+                                    std::move(release_fence));
+    return;
+  }
+#endif
+  LOG(ERROR) << "Accelerated paint release without an offscreen output";
 }
 
