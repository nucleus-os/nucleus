index 000000000..2dc688205
--- /dev/null
+++ b/cef/libcef/browser/osr/external_begin_frame_state_unittest.cc
@@ -0,0 +1,69 @@
+// Copyright (c) 2026 The Chromium Embedded Framework Authors.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "cef/libcef/browser/osr/external_begin_frame_state.h"
+
+#include "tests/gtest/include/gtest/gtest.h"
+
+namespace {
+
+class ReentrantCallback : public CefExternalBeginFrameCallback {
+ public:
+  explicit ReentrantCallback(CefExternalBeginFrameState* state)
+      : state_(state) {}
+
+  void OnComplete(bool has_damage) override {
+    called_ = true;
+    has_damage_ = has_damage;
+    reentrant_begin_accepted_ = state_->Begin(nullptr);
+  }
+
+  bool called() const { return called_; }
+  bool has_damage() const { return has_damage_; }
+  bool reentrant_begin_accepted() const { return reentrant_begin_accepted_; }
+
+ private:
+  CefExternalBeginFrameState* state_;
+  bool called_ = false;
+  bool has_damage_ = false;
+  bool reentrant_begin_accepted_ = false;
+
+  IMPLEMENT_REFCOUNTING(ReentrantCallback);
+};
+
+}  // namespace
+
+TEST(ExternalBeginFrameState, RejectsSecondRequestAndCompletesExactlyOnce) {
+  CefExternalBeginFrameState state;
+  CefRefPtr<ReentrantCallback> callback = new ReentrantCallback(&state);
+
+  EXPECT_TRUE(state.Begin(callback));
+  EXPECT_TRUE(state.pending());
+  EXPECT_FALSE(state.Begin(nullptr));
+
+  state.Complete(true);
+  EXPECT_TRUE(callback->called());
+  EXPECT_TRUE(callback->has_damage());
+  EXPECT_TRUE(callback->reentrant_begin_accepted());
+  EXPECT_TRUE(state.pending());
+
+  state.Complete(false);
+  EXPECT_FALSE(state.pending());
+}
+
+TEST(ExternalBeginFrameState, PreservesExactPresentationTiming) {
+  constexpr int64_t kIntervalNs = 8'333'333;
+  constexpr int64_t kDeadlineDeltaNs = 4'123'456;
+  const base::TimeTicks frame_time = base::TimeTicks::Now();
+
+  const viz::BeginFrameArgs args = MakeExternalBeginFrameArgs(
+      7, 11, frame_time, kDeadlineDeltaNs, kIntervalNs);
+
+  EXPECT_TRUE(args.IsValid());
+  EXPECT_EQ(args.frame_id.source_id, 7u);
+  EXPECT_EQ(args.frame_id.sequence_number, 11u);
+  EXPECT_EQ(args.frame_time, frame_time);
+  EXPECT_EQ(args.deadline, frame_time + base::Nanoseconds(kDeadlineDeltaNs));
+  EXPECT_EQ(args.interval, base::Nanoseconds(kIntervalNs));
+}
