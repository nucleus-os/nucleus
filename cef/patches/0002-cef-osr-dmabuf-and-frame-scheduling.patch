@@ -744,6 +760,43 @@ class CefBrowserHost : public virtual CefBaseRefCounted {
   /*--cef()--*/
   virtual void SendExternalBeginFrame() = 0;

+  ///
+  /// Issue a presentation-timed BeginFrame request to Chromium. This method
+  /// must be called on the CEF UI thread and is only valid when
+  /// CefWindowInfo::external_begin_frame_enabled is true. Returns true if the
+  /// request was accepted. Only one request may be outstanding at a time.
+  /// When accepted, |callback| will be called after Chromium acknowledges the
+  /// matching BeginFrame, including when that frame produces no damage.
+  ///
+  /*--cef()--*/
+  virtual bool SendExternalBeginFrameWithTiming(
+      const CefExternalBeginFrameArgs& args,
+      CefRefPtr<CefExternalBeginFrameCallback> callback) = 0;
+
+  ///
+  /// Abort any outstanding external BeginFrame in place. The accepted frame's
+  /// callback will still run exactly once with no damage. This method must be
+  /// called on the CEF UI thread for a windowless browser with external
+  /// BeginFrame control enabled.
+  ///
+  /*--cef()--*/
+  virtual bool AbortPendingExternalBeginFrame() = 0;
+
+  ///
+  /// Set a release fence for the accelerated paint frame identified by
