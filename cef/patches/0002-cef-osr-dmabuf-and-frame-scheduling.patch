+void CefRenderWidgetHostViewOSR::OnOutputError(
+    viz::mojom::OffscreenOutputError error) {
+  LOG(ERROR) << "Offscreen output export failed: " << static_cast<int>(error);
+  if (offscreen_output_recovery_pending_ || is_destroyed_) {
+    return;
+  }
+
+  offscreen_output_client_receiver_.reset();
+  offscreen_output_.reset();
+  ++offscreen_output_epoch_;
+  ++external_begin_frame_generation_;
+  if (begin_frame_state_.pending()) {
+    begin_frame_state_.Complete(false);
+  }
+
+  // Recreate outside the Mojo callback. Destroying the output's compositor
+  // synchronously from its error notification can tear down the dispatch
+  // stack that is still delivering this call.
+  offscreen_output_recovery_pending_ = true;
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&CefRenderWidgetHostViewOSR::RecoverOffscreenOutput,
+                     weak_ptr_factory_.GetWeakPtr()));
+}
+
+void CefRenderWidgetHostViewOSR::RecoverOffscreenOutput() {
+  offscreen_output_recovery_pending_ = false;
+  if (is_destroyed_ || !render_widget_host_) {
+    return;
+  }
+
+  const bool was_showing = is_showing_;
+  ReleaseCompositor();
+  InitializeCompositor();
+  SetRootLayerSize(/*force=*/true);
+  InvalidateLocalSurfaceId();
+  SynchronizeVisualProperties(cc::DeadlinePolicy::UseDefaultDeadline(),
+                              std::nullopt);
+
+  if (was_showing) {
+    delegated_frame_host_->AttachToCompositor(compositor_.get());
+    delegated_frame_host_->WasShown(GetLocalSurfaceId(), GetViewBounds().size(),
+                                    /*record_tab_switch_time_request=*/{});
+  }
+  InvalidateInternal(gfx::Rect(SizeInPixels()));
+}
