+bool AlloyBrowserHostImpl::SendExternalBeginFrameWithTiming(
+    const CefExternalBeginFrameArgs& args,
+    CefRefPtr<CefExternalBeginFrameCallback> callback) {
+  if (!IsWindowless() || !CEF_CURRENTLY_ON_UIT()) {
+    DCHECK(false) << "Timed external BeginFrames require windowless rendering "
+                     "on the CEF UI thread";
+    return false;
+  }
+
+  return platform_delegate_ &&
+         platform_delegate_->SendExternalBeginFrameWithTiming(args, callback);
+}
+
+bool AlloyBrowserHostImpl::AbortPendingExternalBeginFrame() {
+  if (!IsWindowless() || !CEF_CURRENTLY_ON_UIT()) {
+    DCHECK(false) << "Aborting an external BeginFrame requires "
+                     "windowless rendering on the CEF UI thread";
+    return false;
+  }
+  return platform_delegate_ &&
+         platform_delegate_->AbortPendingExternalBeginFrame();
+}
+
+void AlloyBrowserHostImpl::SetAcceleratedPaintReleaseFence(
+    uint64_t transport_epoch,
+    int64_t capture_counter,
+    int fd) {
+  if (!IsWindowless() || !CEF_CURRENTLY_ON_UIT()) {
+    DCHECK(false) << "Release fences require windowless rendering on the CEF "
+                     "UI thread";
+    return;
+  }
+
+  if (platform_delegate_) {
