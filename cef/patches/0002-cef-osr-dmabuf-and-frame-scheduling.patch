@@ -0,0 +1,42 @@
+// Copyright (c) 2026 The Chromium Embedded Framework Authors.
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "cef/libcef/browser/osr/external_begin_frame_state.h"
+
+#include <utility>
+
+#include "base/check.h"
+
+bool CefExternalBeginFrameState::Begin(
+    CefRefPtr<CefExternalBeginFrameCallback> callback) {
+  if (pending_) {
+    return false;
+  }
+  pending_ = true;
+  callback_ = callback;
+  return true;
+}
+
+void CefExternalBeginFrameState::Complete(bool has_damage) {
+  CHECK(pending_);
+  CefRefPtr<CefExternalBeginFrameCallback> callback = std::move(callback_);
+  pending_ = false;
+  if (callback) {
+    callback->OnComplete(has_damage);
+  }
+}
+
+viz::BeginFrameArgs MakeExternalBeginFrameArgs(
+    uint64_t source_id,
+    uint64_t sequence_number,
+    base::TimeTicks frame_time,
+    int64_t deadline_delta_ns,
+    int64_t interval_ns) {
+  CHECK_GT(deadline_delta_ns, 0);
+  CHECK_GT(interval_ns, 0);
+  return viz::BeginFrameArgs::Create(
+      BEGINFRAME_FROM_HERE, source_id, sequence_number, frame_time,
+      frame_time + base::Nanoseconds(deadline_delta_ns),
+      base::Nanoseconds(interval_ns), viz::BeginFrameArgs::NORMAL);
+}
