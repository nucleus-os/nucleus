+  /// be called on the CEF UI thread before CEF's bounded release timeout. CEF
+  /// duplicates |fd| before returning, and the caller retains ownership of
+  /// |fd|. The frame capture buffer will not be recycled until the fence
+  /// signals.
+  ///
+  /*--cef()--*/
+  virtual void SetAcceleratedPaintReleaseFence(uint64_t transport_epoch,
+                                               int64_t capture_counter,
+                                               int fd) = 0;
+
