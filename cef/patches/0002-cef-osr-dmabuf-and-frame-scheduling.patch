+void CefRenderWidgetHostViewOSR::SetAcceleratedPaintReleaseFence(
+    uint64_t transport_epoch,
+    int64_t capture_counter,
+    int fd) {
+#if BUILDFLAG(IS_LINUX)
+  if (transport_epoch != offscreen_output_epoch_) {
+    return;
+  }
+  if (offscreen_output_.is_bound()) {
+    base::ScopedFD duplicated_fd(HANDLE_EINTR(dup(fd)));
+    if (!duplicated_fd.is_valid()) {
+      LOG(ERROR) << "Failed to duplicate accelerated paint release fence";
+      return;
+    }
+    gfx::GpuFenceHandle release_fence;
+    release_fence.Adopt(std::move(duplicated_fd));
+    offscreen_output_->ReleaseFrame(capture_counter, std::move(release_fence));
+    return;
+  }
+#endif
+  LOG(ERROR) << "Accelerated paint release without an offscreen output";
 }
 
