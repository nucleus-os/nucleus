+///
+/// Callback for CefBrowserHost::SendExternalBeginFrameWithTiming. OnComplete
+/// is called on the CEF UI thread after Chromium acknowledges the accepted
+/// BeginFrame. |has_damage| reflects the matching BeginFrameAck.
+///
+/*--cef(source=client)--*/
+class CefExternalBeginFrameCallback : public virtual CefBaseRefCounted {
+ public:
+  ///
+  /// Called after Chromium acknowledges the accepted BeginFrame.
+  /// |has_damage| will be true if the frame produced visual damage.
+  ///
+  /*--cef()--*/
+  virtual void OnComplete(bool has_damage) = 0;
+};
