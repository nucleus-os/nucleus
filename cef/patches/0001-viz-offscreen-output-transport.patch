+
+// A completed root-compositor output image borrowed by an external consumer.
+// Every valid frame_token must be released exactly once through
+// OffscreenOutput.ReleaseFrame before its backing can be reused.
+struct OffscreenOutputFrame {
+  uint64 generation;
+  uint32 slot_index;
+  uint64 content_serial;
+  uint64 frame_token;
+
+  gfx.mojom.Size coded_size;
+  gfx.mojom.Rect visible_rect;
+  gfx.mojom.Rect damage_rect;
+
+  SharedImageFormat format;
+  gfx.mojom.ColorSpace color_space;
+  skia.mojom.AlphaType alpha_type;
+  OffscreenOutputOrigin origin;
+  // Vulkan queue family that owns the image at the external handoff.
+  uint32 queue_family_index;
+  // Vulkan layout guaranteed while ownership is external to Viz.
+  uint32 image_layout;
+
+  // Owns duplicated native-pixmap plane descriptors for transfer to the
+  // external consumer.
+  gfx.mojom.NativePixmapHandle native_pixmap;
+  gfx.mojom.GpuFenceHandle acquire_fence;
+
+  mojo_base.mojom.TimeTicks frame_time;
+  uint64 swap_trace_id;
+};
+
+// Implemented by the privileged browser-side consumer.
+interface OffscreenOutputClient {
+  OnFrameAvailable(OffscreenOutputFrame frame);
+  OnOutputError(OffscreenOutputError error);
+};
+
+// Implemented by Viz for an explicitly requested exportable offscreen root.
+interface OffscreenOutput {
+  // Returns the consumer-completion fence for frame_token. A null fence is not
+  // permission to recycle the backing and is treated as a protocol error.
+  ReleaseFrame(uint64 frame_token, gfx.mojom.GpuFenceHandle release_fence);
+};
