# Pinned upstream versions for Foundation's C library dependencies, plus
# their tarball SHA-256 checksums. Sourced by recipes/*.sh.
#
# Bump policy:
#   - Patch bumps (1.2.3 -> 1.2.4) are usually safe; verify by re-running
#     ./build.sh and checking the smoke test still passes.
#   - Minor/major bumps may shift the Foundation feature surface; cross-
#     check Apple's libcurl.pc/openssl-version reporting before bumping.
#   - Update sha256 from each project's published release signatures, not
#     from a casual mirror.

# Leaf deps (no other deps from this list).
ZLIB_VERSION="1.3.1"
ZLIB_SHA256="9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23"
# Use the GitHub release mirror — zlib.net rotates the canonical URL to
# whatever the latest release is, so a pinned-version URL there 404s.
ZLIB_URL="https://github.com/madler/zlib/releases/download/v${ZLIB_VERSION}/zlib-${ZLIB_VERSION}.tar.gz"

XZ_VERSION="5.6.3"
XZ_SHA256="b1d45295d3f71f25a4c9101bd7c8d16cb56348bbef3bbc738da0351e17c73317"
XZ_URL="https://github.com/tukaani-project/xz/releases/download/v${XZ_VERSION}/xz-${XZ_VERSION}.tar.gz"

LIBICONV_VERSION="1.17"
LIBICONV_SHA256="8f74213b56238c85a50a5329f77e06198771e70dd9a739779f4c02f65d971313"
LIBICONV_URL="https://ftp.gnu.org/pub/gnu/libiconv/libiconv-${LIBICONV_VERSION}.tar.gz"

# Middle layer (depends on leaf).
OPENSSL_VERSION="3.4.0"
OPENSSL_SHA256="e15dda82fe2fe8139dc2ac21a36d4ca01d5313c75f99f46c4e8a27709b7294bf"
OPENSSL_URL="https://github.com/openssl/openssl/releases/download/openssl-${OPENSSL_VERSION}/openssl-${OPENSSL_VERSION}.tar.gz"

NGHTTP2_VERSION="1.64.0"
NGHTTP2_SHA256="88bb94c9e4fd1c499967f83dece36a78122af7d5fb40da2019c56b9ccc6eb9dd"
NGHTTP2_URL="https://github.com/nghttp2/nghttp2/releases/download/v${NGHTTP2_VERSION}/nghttp2-${NGHTTP2_VERSION}.tar.xz"

# Top layer.
LIBCURL_VERSION="8.11.0"
LIBCURL_SHA256="264537d90e58d2b09dddc50944baf3c38e7089151c8986715e2aaeaaf2b8118f"
LIBCURL_URL="https://curl.se/download/curl-${LIBCURL_VERSION}.tar.gz"

LIBXML2_VERSION="2.13.5"
LIBXML2_SHA256="74fc163217a3964257d3be39af943e08861263c4231f9ef5b496b6f6d4c7b2b6"
LIBXML2_URL="https://download.gnome.org/sources/libxml2/2.13/libxml2-${LIBXML2_VERSION}.tar.xz"
